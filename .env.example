# Supabase — salin ke .env.local dan isi dengan nilai project kamu.
# JANGAN commit .env.local.

# Aman diekspos ke browser (dilindungi Row Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RAHASIA — hanya dipakai di server (Server Actions / Route Handlers).
# Melewati RLS, jadi WAJIB hanya dipakai setelah validasi server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret untuk menandatangani token sesi game (HMAC anti-cheat).
# Gunakan string acak panjang (mis. `openssl rand -hex 32`).
GAME_SESSION_SECRET=replace-with-long-random-hex-string
